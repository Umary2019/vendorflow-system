{
  "version": 2,
  "installCommand": "npm install",
  "functions": {
    "api/index.js": {
      "maxDuration": 10
    }
  },
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/uploads/(.*)",
      "dest": "/api/index.js?path=uploads/$1"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js?path=$1"
    },
    {
      "src": "/api",
      "dest": "/api/index.js?path="
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
