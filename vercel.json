{
  "version": 2,
  "installCommand": "npm install",
  "functions": {
    "api/[...path].js": {
      "maxDuration": 10
    }
  },
  "builds": [
    {
      "src": "api/[...path].js",
      "use": "@vercel/node"
    },
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ]
}
